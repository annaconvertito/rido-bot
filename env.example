# =============================================
# Ri-Do Bot — Variabili d'ambiente
# =============================================
# Copia questo file in .env e compila i valori
# NON committare .env su GitHub!

# Token della Pagina Facebook
# Lo trovi su: developers.facebook.com → tua app → Messenger → Impostazioni
PAGE_ACCESS_TOKEN=inserisci_qui_il_token_della_pagina

# Token di verifica — inventalo tu, deve essere uguale a quello inserito su Meta
VERIFY_TOKEN=rido-verify-2026

# Porta del server (Render/Railway la impostano automaticamente)
PORT=3000
